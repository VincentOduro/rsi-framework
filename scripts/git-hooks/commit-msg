#!/bin/bash
# Commit-msg hook — BLOCKS commit if code changes without memory update
# Principle 5: Stop and fix quality problems before proceeding
# Installed via: ~/.git_template/hooks/ (system-wide) or git config core.hooksPath

set -e

# Resolve symlink using Python (works on Linux, macOS, Windows Git Bash)
if [ -x "$(command -v python3)" ]; then
    REAL_PATH="$(python3 -c "import os; print(os.path.realpath('$BASH_SOURCE[0]'))")"
else
    REAL_PATH="$BASH_SOURCE[0]"
fi
PROJECT_ROOT="$(cd "$(dirname "$REAL_PATH")/../.." && pwd)"
cd "$PROJECT_ROOT"

RED='\033[91m'
GREEN='\033[92m'
RESET='\033[0m'

# Get files in this commit
COMMIT_FILES=$(git diff --cached --name-only --diff-filter=ACM)
SRC_CHANGED=$(echo "$COMMIT_FILES" | grep -E "^src/.*\.py$" || true)
MEMORY_CHANGED=$(echo "$COMMIT_FILES" | grep -E "^(\.memory/|MEMORY\.md|scripts/(post_implementation|self_feedback|self_optimization)\.py)" || true)

# If code changed but no memory update, BLOCK
if [ -n "$SRC_CHANGED" ] && [ -z "$MEMORY_CHANGED" ]; then
    echo ""
    echo "${RED}✗ COMMIT BLOCKED — Source files changed without memory update${RESET}"
    echo ""
    echo "Changed source files:"
    echo "$SRC_CHANGED" | sed 's/^/  /'
    echo ""
    echo "Memory files in this commit: (none)"
    echo ""
    echo "Before committing, you MUST run:"
    echo "  python3 scripts/post_implementation.py --interactive"
    echo "  python3 scripts/self_feedback.py"
    echo "  python3 scripts/self_optimization.py"
    echo ""
    echo "This is a mandatory gate, not a warning."
    exit 1
fi

exit 0

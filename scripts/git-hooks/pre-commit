#!/bin/bash
# Pre-commit hook — BLOCKS commit if quality checks fail
# Principle 5: Stop and fix quality problems before proceeding
# Principle 12: Genchi Genbutsu — read files before editing
# Installed via: ~/.git_template/hooks/ (system-wide) or git config core.hooksPath

set -e

# Resolve symlink to get real path, then go up to project root
# Python's os.path.realpath works on Linux, macOS, and Windows Git Bash
# Hook installed via: ln -s or core.hooksPath pointing to scripts/git-hooks/
# BASH_SOURCE[0] = .git/hooks/pre-commit (symlink) → resolves to scripts/git-hooks/pre-commit
if [ -x "$(command -v python3)" ]; then
    REAL_PATH="$(python3 -c "import os; print(os.path.realpath('$BASH_SOURCE[0]'))")"
else
    # Fallback for systems without Python
    REAL_PATH="$BASH_SOURCE[0]"
fi
PROJECT_ROOT="$(cd "$(dirname "$REAL_PATH")/../.." && pwd)"
cd "$PROJECT_ROOT"

RED='\033[91m'
GREEN='\033[92m'
YELLOW='\033[93m'
RESET='\033[0m'

echo "Running pre-commit checks..."

# ---- 0. Session check: verify an active RSI session exists ----
echo ""
echo "[SESSION] Checking for active RSI session..."
SESSION_RESULT=$(python3 -B "$PROJECT_ROOT/scripts/preflight_check.py" --require-session 2>&1)
SESSION_EXIT=$?
echo "$SESSION_RESULT"
if [ $SESSION_EXIT -ne 0 ]; then
    echo "${RED}✗ SESSION CHECK FAILED — run 'python3 scripts/preflight_check.py --start' first${RESET}"
    exit 1
fi
echo "${GREEN}✓ Session active${RESET}"

# ---- 1. Pre-flight: verify files were read before being edited ----
echo ""
echo "[PRE-FLIGHT] Checking if files were read before being edited..."
PREFLIGHT_RESULT=$(python3 -B "$PROJECT_ROOT/scripts/preflight_check.py" --check-edited 2>&1)
PREFLIGHT_EXIT=$?
if [ $PREFLIGHT_EXIT -ne 0 ]; then
    echo "$PREFLIGHT_RESULT"
    echo "${RED}✗ Pre-flight FAILED — files edited without being read${RESET}"
    echo ""
    echo "You MUST read files before editing them."
    echo "To record reading: python3 scripts/preflight_check.py --record FILE"
    exit 1
else
    echo "${GREEN}✓ Pre-flight passed${RESET}"
fi

# ---- 1. Get changed files ----
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
SRC_CHANGED=$(echo "$CHANGED_FILES" | grep -E "^src/.*\.py$" || true)
SCRIPT_CHANGED=$(echo "$CHANGED_FILES" | grep -E "^scripts/.*\.(py|sh)$" || true)

# ---- 2. If source files changed, run self_verify ----
if [ -n "$SRC_CHANGED" ]; then
    echo ""
    echo "[SELF-VERIFY] Running self-verify on changed files..."
    SRC_ARGS=$(echo "$SRC_CHANGED" | tr '\n' ' ')

    CHECK_RESULT=$(python3 -B "$PROJECT_ROOT/scripts/self_verify.py" --files $SRC_ARGS --skip-tests 2>&1)
    CHECK_EXIT=$?

    if [ $CHECK_EXIT -ne 0 ]; then
        echo ""
        echo "${RED}✗ self_verify FAILED — commit blocked${RESET}"
        echo "$CHECK_RESULT" | tail -10
        echo ""
        echo "Fix the issues above, then retry commit."
        exit 1
    else
        echo "${GREEN}✓ self_verify passed${RESET}"
        for f in $SRC_CHANGED; do
            python3 -B "$PROJECT_ROOT/scripts/preflight_check.py" --record "$f" 2>/dev/null
        done
    fi
fi

# ---- 3. If scripts changed, check syntax ----
if [ -n "$SCRIPT_CHANGED" ]; then
    echo ""
    echo "[SYNTAX] Checking scripts..."
    for f in $SCRIPT_CHANGED; do
        if [[ "$f" == *.py ]]; then
            python3 -B -m py_compile "$PROJECT_ROOT/$f" 2>&1 || {
                echo "${RED}✗ Syntax error in $f${RESET}"
                exit 1
            }
        elif [[ "$f" == *.sh ]]; then
            bash -n "$PROJECT_ROOT/$f" 2>&1 || {
                echo "${RED}✗ Shell syntax error in $f${RESET}"
                exit 1
            }
        fi
    done
    echo "${GREEN}✓ Script syntax OK${RESET}"
    for f in $SCRIPT_CHANGED; do
        python3 -B "$PROJECT_ROOT/scripts/preflight_check.py" --record "$f" 2>/dev/null
    done
fi

# ---- 4. Ceremony probe (configurable via pre_commit_strictness) ----
STRICTNESS=$(python3 -B -c "
import re
try:
    content = open('.rsi/architecture.yaml', encoding='utf-8').read()
    m = re.search(r'^pre_commit_strictness:\s*[\"\']?([\w_]+)', content, re.MULTILINE)
    print(m.group(1) if m else 'verify_warn')
except Exception:
    print('verify_warn')
" 2>/dev/null)
STRICTNESS=${STRICTNESS:-verify_warn}

if [ "$STRICTNESS" != "preflight_only" ]; then
    echo ""
    echo "[CEREMONY] Running ceremony classifier probe..."
    CEREMONY_OUTPUT=$(python3 -B -m scripts.ceremony --json 2>&1) || CEREMONY_EXIT=$?
    CEREMONY_EXIT=${CEREMONY_EXIT:-0}

    if [ $CEREMONY_EXIT -ne 0 ]; then
        if [ "$STRICTNESS" = "verify_strict" ]; then
            echo "${RED}✗ CEREMONY probe FAILED — commit blocked (verify_strict mode)${RESET}"
            exit 1
        else
            echo "${YELLOW}WARNING: ceremony classifier did not return clean output${RESET}"
            echo "Ceremony module is surfacing an issue but not blocking the commit (verify_warn mode)."
        fi
    else
        CEREMONY_LEVEL=$(echo "$CEREMONY_OUTPUT" | python3 -B -c "
import sys, json
try:
    data = json.load(sys.stdin)
    level = data.get('level', 'unknown')
    print(f'level: {level}')
except Exception:
    print('level: unknown')
" 2>/dev/null)
        if [ "$STRICTNESS" = "verify_strict" ]; then
            echo "${GREEN}✓ Ceremony probe passed${RESET}"
        fi
        echo "[CEREMONY] ${CEREMONY_LEVEL:-level: unknown}"
    fi
fi

echo ""
echo "${GREEN}✓ Pre-commit checks complete${RESET}"
exit 0
